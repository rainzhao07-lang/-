# ===== LLM(OpenAI 兼容接口,默认对接 DeepSeek)=====
LLM_BASE_URL=          # 例如 https://api.deepseek.com
LLM_API_KEY=           # 留空时进入本地 mock 模式(仅用于开发验证,不产生费用)
LLM_MODEL=             # 例如 deepseek-chat

# ===== Supabase(服务端专用,前端绝不可见)=====
SUPABASE_URL=          # 留空时使用内存数据库(仅用于本地开发,重启即失)
SUPABASE_SERVICE_ROLE_KEY=

# ===== 管理 API =====
ADMIN_SECRET=          # /api/admin/codes 的鉴权密钥,自定义一段强随机字符串

# ===== 支付(兑换码模式)=====
NEXT_PUBLIC_PAY_URL=   # 面包多/发卡网商品页外链

# ===== 站点 =====
NEXT_PUBLIC_SITE_URL=  # 正式域名,用于分享卡短链与社交分享 meta,例如 https://benmingmao.example.com
